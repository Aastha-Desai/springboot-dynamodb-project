{
  "family": "{{TASK_FAMILY}}",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::{{AWS_ACCOUNT_ID}}:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "dynamodb-demo",
      "image": "{{IMAGE_URI}}",
      "portMappings": [ { "containerPort": 8080, "protocol": "tcp" } ],
      "essential": true,
      "environment": []
    }
  ]
}
