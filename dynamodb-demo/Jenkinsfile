pipeline {
  agent any
  parameters {
    string(name: 'AWS_ACCOUNT_ID', defaultValue: '464868388928', description: 'AWS account id')
    string(name: 'ECR_REPO', defaultValue: 'dynamodb-demo', description: 'ECR repository name')
    string(name: 'CLUSTER_NAME', defaultValue: 'dynamodb-demo-cluster', description: 'ECS cluster name')
    string(name: 'SERVICE_NAME', defaultValue: 'dynamodb-demo-service', description: 'ECS service name')
    string(name: 'TASK_FAMILY', defaultValue: 'dynamodb-demo-task', description: 'ECS task family')
    string(name: 'IMAGE_TAG', defaultValue: '', description: 'Optional Docker image tag. Leave blank to use a build-specific immutable tag.')
    string(name: 'AGENT_EMAIL_MODE', defaultValue: 'smtp', description: 'Agent email mode when validation fails: smtp, preview, or auto')
    booleanParam(name: 'RUN_ECS_MONITOR', defaultValue: false, description: 'Optional manual ECS monitor check. Normal builds only invoke the agent after validation fails.')
    booleanParam(name: 'FORCE_VALIDATION_FAILURE', defaultValue: false, description: 'Demo/test Part 8 rollback by forcing deployment validation to fail')
  }
  environment {
    AWS_REGION = "us-east-1"
    AWS_ACCOUNT_ID = "${params.AWS_ACCOUNT_ID}"
    ECR_REPO = "${params.ECR_REPO}"
    CLUSTER_NAME = "${params.CLUSTER_NAME}"
    SERVICE_NAME = "${params.SERVICE_NAME}"
    TASK_FAMILY = "${params.TASK_FAMILY}"
    AGENT_EMAIL_MODE = "${params.AGENT_EMAIL_MODE}"
    AGENT_IMAGE = "agent-runner:build-${BUILD_NUMBER}"
    PREVIOUS_TASK_DEFINITION = ""
  }
  stages {
    stage('Checkout') {
      steps { checkout scm }
    }
    stage('Set Image Tag') {
      steps {
        sh '''
          EFFECTIVE_IMAGE_TAG="${IMAGE_TAG:-}"
          if [ -z "${EFFECTIVE_IMAGE_TAG}" ] || [ "${EFFECTIVE_IMAGE_TAG}" = "null" ]; then
            EFFECTIVE_IMAGE_TAG="build-${BUILD_NUMBER}"
          fi
          echo "${EFFECTIVE_IMAGE_TAG}" > .effective-image-tag
          echo "Docker image tag for this deployment: ${EFFECTIVE_IMAGE_TAG}"
        '''
      }
    }
    stage('Build') {
      steps {
        dir('dynamodb-demo') {
          sh './mvnw -B -DskipTests package'
        }
      }
    }
    stage('Build Agent Runner Image') {
      steps {
        sh 'docker build -f agent-runner/Dockerfile -t "${AGENT_IMAGE}" .'
      }
    }
    stage('Test') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          script {
            try {
              dir('dynamodb-demo') {
                sh './mvnw test -q'
              }
            } catch (testError) {
              echo "Tests failed. Invoking external agent-runner container to prepare a fix PR and human approval email."
              def baseBranch = env.BRANCH_NAME ?: 'main'
              def fixBranch = "agent-test-fix-${env.BUILD_NUMBER}"
              runAgentContainer('com.example.agent.JavaOrchestratorAgent',
                  "--skip-monitor --config /opt/agent-config/project-config.json --repo-dir .. --project-dir ../dynamodb-demo --region ${env.AWS_REGION} --audit-table AgentAudit --email-mode ${env.AGENT_EMAIL_MODE} --base-branch ${baseBranch} --fix-branch ${fixBranch} --paths dynamodb-demo/src/main/java/com/example/dynamodb_demo/model/Employee.java --commit-message \"fix: apply validation test fix\" --pr-title \"Agent fix: restore validation rule\" --summary \"Jenkins tests failed, and the external Java agent container generated this PR for human approval.\"")
              error "Tests failed; the external agent container was invoked for PR/email approval."
            }
          }
        }
      }
    }
    stage('Build & Push Image') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          dir('dynamodb-demo') {
            sh '''
              EFFECTIVE_IMAGE_TAG="$(cat ../.effective-image-tag)"
              ./scripts/ecr_login_and_push.sh "${AWS_ACCOUNT_ID}" "${AWS_REGION}" "${ECR_REPO}" "${EFFECTIVE_IMAGE_TAG}"
            '''
          }
        }
      }
    }
    stage('Capture Current ECS Version') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          sh '''
            PREVIOUS_TASK_DEFINITION="$(aws ecs describe-services \
              --cluster "${CLUSTER_NAME}" \
              --services "${SERVICE_NAME}" \
              --region "${AWS_REGION}" \
              --query 'services[0].deployments[?status==`PRIMARY`].taskDefinition | [0]' \
              --output text)"

            if [ -z "${PREVIOUS_TASK_DEFINITION}" ] || [ "${PREVIOUS_TASK_DEFINITION}" = "None" ] || [ "${PREVIOUS_TASK_DEFINITION}" = "null" ]; then
              echo "Could not capture previous ECS task definition for ${CLUSTER_NAME}/${SERVICE_NAME}." >&2
              exit 2
            fi

            echo "${PREVIOUS_TASK_DEFINITION}" > .previous-task-definition
            echo "Previous ECS task definition: ${PREVIOUS_TASK_DEFINITION}"
          '''
        }
      }
    }
    stage('Deploy to ECS') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          dir('dynamodb-demo') {
            sh '''
              EFFECTIVE_IMAGE_TAG="$(cat ../.effective-image-tag)"
              ./scripts/deploy_ecs.sh "${AWS_ACCOUNT_ID}" "${AWS_REGION}" "${CLUSTER_NAME}" "${SERVICE_NAME}" "${TASK_FAMILY}" "${ECR_REPO}" "${EFFECTIVE_IMAGE_TAG}"
            '''
          }
        }
      }
    }
    stage('Validate ECS Deployment') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          script {
            def validationArgs = '--config /opt/agent-config/project-config.json --region ${AWS_REGION} --cluster ${CLUSTER_NAME} --service ${SERVICE_NAME} --audit-table AgentAudit'
            if (params.FORCE_VALIDATION_FAILURE) {
              validationArgs = validationArgs + ' --force-fail'
            }
            try {
              runAgentContainer('com.example.agent.JavaValidateEcsDeploymentAgent', validationArgs)
            } catch (validationError) {
              echo "Deployment validation failed. Rolling back ECS service to the captured previous task definition."
              sh '''
                PREVIOUS_TASK_DEFINITION="$(cat .previous-task-definition)"
                dynamodb-demo/scripts/rollback_ecs.sh "${AWS_REGION}" "${CLUSTER_NAME}" "${SERVICE_NAME}" "${PREVIOUS_TASK_DEFINITION}" AgentAudit
              '''
              runAgentContainer('com.example.agent.JavaValidateEcsDeploymentAgent',
                  '--config /opt/agent-config/project-config.json --region ${AWS_REGION} --cluster ${CLUSTER_NAME} --service ${SERVICE_NAME} --audit-table AgentAudit')

              echo "Rollback validated. Invoking external agent-runner container to prepare a fix PR and human approval email."
              def baseBranch = env.BRANCH_NAME ?: 'main'
              def fixBranch = "agent-validation-fix-${env.BUILD_NUMBER}"
              runAgentContainer('com.example.agent.JavaOrchestratorAgent',
                  "--skip-monitor --config /opt/agent-config/project-config.json --repo-dir .. --project-dir ../dynamodb-demo --region ${env.AWS_REGION} --audit-table AgentAudit --email-mode ${env.AGENT_EMAIL_MODE} --base-branch ${baseBranch} --fix-branch ${fixBranch} --paths dynamodb-demo/src/main/java/com/example/dynamodb_demo/model/Employee.java --commit-message \"fix: apply validation bug fix\" --pr-title \"Agent fix: restore validation rule\" --summary \"Jenkins validation failed, ECS was rolled back, and the external Java agent container generated this PR for human approval.\"")
              error "Deployment validation failed; ECS was rolled back and the external agent container was invoked for PR/email approval."
            }
          }
        }
      }
    }
    stage('Monitor ECS') {
      when {
        expression { return params.RUN_ECS_MONITOR }
      }
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          script {
            runAgentContainer('com.example.agent.JavaEcsMonitorAgent',
                '--config /opt/agent-config/project-config.json --region ${AWS_REGION} --cluster ${CLUSTER_NAME} --service ${SERVICE_NAME} --audit-table AgentAudit')
          }
        }
      }
    }
  }
}

def runAgentContainer(String mainClass, String args) {
  sh """
    docker run --rm \
      --user "\$(id -u):\$(id -g)" \
      -e HOME=/tmp \
      -e AGENT_MAIN_CLASS="${mainClass}" \
      -e AWS_ACCESS_KEY_ID \
      -e AWS_SECRET_ACCESS_KEY \
      -e AWS_SESSION_TOKEN \
      -e AWS_REGION="${env.AWS_REGION}" \
      -e GITHUB_TOKEN \
      -e GH_TOKEN \
      -e APPROVAL_EMAIL_TO \
      -e EMAIL_FROM \
      -e SMTP_HOST \
      -e SMTP_PORT \
      -e SMTP_USERNAME \
      -e SMTP_PASSWORD \
      -e GIT_AUTHOR_NAME \
      -e GIT_AUTHOR_EMAIL \
      -v "\${WORKSPACE}:/workspace" \
      -w /workspace/agent-runner \
      "${env.AGENT_IMAGE}" ${args}
  """
}
