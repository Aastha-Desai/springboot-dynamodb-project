pipeline {
  agent any
  parameters {
    string(name: 'AWS_ACCOUNT_ID', defaultValue: '464868388928', description: 'AWS account id')
    string(name: 'ECR_REPO', defaultValue: 'dynamodb-demo', description: 'ECR repository name')
    string(name: 'CLUSTER_NAME', defaultValue: 'dynamodb-demo-cluster', description: 'ECS cluster name')
    string(name: 'SERVICE_NAME', defaultValue: 'dynamodb-demo-service', description: 'ECS service name')
    string(name: 'TASK_FAMILY', defaultValue: 'dynamodb-demo-task', description: 'ECS task family')
    string(name: 'IMAGE_TAG', defaultValue: '', description: 'Optional Docker image tag. Leave blank to use a build-specific immutable tag.')
    booleanParam(name: 'FORCE_VALIDATION_FAILURE', defaultValue: false, description: 'Demo/test Part 8 rollback by forcing deployment validation to fail')
  }
  environment {
    AWS_REGION = "us-east-1"
    AWS_ACCOUNT_ID = "${params.AWS_ACCOUNT_ID}"
    ECR_REPO = "${params.ECR_REPO}"
    CLUSTER_NAME = "${params.CLUSTER_NAME}"
    SERVICE_NAME = "${params.SERVICE_NAME}"
    TASK_FAMILY = "${params.TASK_FAMILY}"
    PREVIOUS_TASK_DEFINITION = ""
  }
  stages {
    stage('Checkout') {
      steps { checkout scm }
    }
    stage('Set Image Tag') {
      steps {
        sh '''
          EFFECTIVE_IMAGE_TAG="${IMAGE_TAG:-}"
          if [ -z "${EFFECTIVE_IMAGE_TAG}" ] || [ "${EFFECTIVE_IMAGE_TAG}" = "null" ]; then
            EFFECTIVE_IMAGE_TAG="build-${BUILD_NUMBER}"
          fi
          echo "${EFFECTIVE_IMAGE_TAG}" > .effective-image-tag
          echo "Docker image tag for this deployment: ${EFFECTIVE_IMAGE_TAG}"
        '''
      }
    }
    stage('Build') {
      steps {
        dir('dynamodb-demo') {
          sh './mvnw -B -DskipTests package'
        }
      }
    }
    stage('Test') {
      steps {
        dir('dynamodb-demo') {
          sh './mvnw test -q'
        }
      }
    }
    stage('Build & Push Image') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          dir('dynamodb-demo') {
            sh '''
              EFFECTIVE_IMAGE_TAG="$(cat ../.effective-image-tag)"
              ./scripts/ecr_login_and_push.sh "${AWS_ACCOUNT_ID}" "${AWS_REGION}" "${ECR_REPO}" "${EFFECTIVE_IMAGE_TAG}"
            '''
          }
        }
      }
    }
    stage('Capture Current ECS Version') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          script {
            env.PREVIOUS_TASK_DEFINITION = sh(
              script: 'aws ecs describe-services --cluster ${CLUSTER_NAME} --services ${SERVICE_NAME} --region ${AWS_REGION} --query "services[0].taskDefinition" --output text',
              returnStdout: true
            ).trim()
            echo "Previous ECS task definition: ${env.PREVIOUS_TASK_DEFINITION}"
          }
        }
      }
    }
    stage('Deploy to ECS') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          dir('dynamodb-demo') {
            sh '''
              EFFECTIVE_IMAGE_TAG="$(cat ../.effective-image-tag)"
              ./scripts/deploy_ecs.sh "${AWS_ACCOUNT_ID}" "${AWS_REGION}" "${CLUSTER_NAME}" "${SERVICE_NAME}" "${TASK_FAMILY}" "${ECR_REPO}" "${EFFECTIVE_IMAGE_TAG}"
            '''
          }
        }
      }
    }
    stage('Validate ECS Deployment') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          dir('dynamodb-demo') {
            script {
              def validationCommand = 'python3 agent/validate_ecs_deployment.py --region ${AWS_REGION} --cluster ${CLUSTER_NAME} --service ${SERVICE_NAME} --audit-table AgentAudit'
              if (params.FORCE_VALIDATION_FAILURE) {
                validationCommand = "${validationCommand} --force-fail"
              }
              try {
                sh validationCommand
              } catch (validationError) {
                echo "Deployment validation failed. Rolling back ECS service to ${env.PREVIOUS_TASK_DEFINITION}."
                sh './scripts/rollback_ecs.sh ${AWS_REGION} ${CLUSTER_NAME} ${SERVICE_NAME} ${PREVIOUS_TASK_DEFINITION} AgentAudit'
                sh 'python3 agent/validate_ecs_deployment.py --region ${AWS_REGION} --cluster ${CLUSTER_NAME} --service ${SERVICE_NAME} --audit-table AgentAudit'
                error "Deployment validation failed; ECS was rolled back to ${env.PREVIOUS_TASK_DEFINITION}."
              }
            }
          }
        }
      }
    }
    stage('Monitor ECS') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'aws', usernameVariable: 'AWS_ACCESS_KEY_ID', passwordVariable: 'AWS_SECRET_ACCESS_KEY')]) {
          dir('dynamodb-demo') {
            sh 'python3 agent/ecs_monitor_agent.py --region ${AWS_REGION} --cluster ${CLUSTER_NAME} --service ${SERVICE_NAME} --audit-table AgentAudit --once'
          }
        }
      }
    }
  }
}
